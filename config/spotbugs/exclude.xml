<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter>
    <Match>
        <Class name="~.*"/>
        <Bug pattern="UWF_FIELD_NOT_INITIALIZED_IN_CONSTRUCTOR,NP_NULL_ON_SOME_PATH_FROM_RETURN_VALUE"/>
        <Annotation name="lombok.Generated"/>
    </Match>

    <Match>
        <Bug pattern="DLS_DEAD_LOCAL_STORE"/>
        <Method name="main"/> </Match>
</FindBugsFilter>
