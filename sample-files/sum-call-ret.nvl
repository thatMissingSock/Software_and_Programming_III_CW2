# calculate the sum of numbers from 1 to 10 using CALL/RET.
# Result will be 55.
#
# Register usage:
# r1: Current number (counter, i), starts at 1
# r2: Sum accumulator, starts at 0
# r3: Loop limit (constant 11)
# r0: Temporary register (used for increment and subtraction check)
#
l1 set r1 1
l2 set r2 0 
l3 set r3 11 
LOOP call SUB_ADD
CHECK sub r0 r3 r1
l4 jnz r0 LOOP 
l5 print r2
l6 halt
#
SUB_ADD add r2 r2 r1
s1 set r0 1
s2 add r1 r1 r0 
s3 ret